  /* ----- Unified dual-bar H2H card (Season + All-Time aligned on win-rate) ----- */
  .h2h-container :global(.h2h-dual-card) {
    text-align: left;
    padding: 1.25rem 1.5rem;
  }
  .h2h-container :global(.h2h-dual-card .h2h-title) {
