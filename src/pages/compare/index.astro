---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import fs from 'node:fs';
import path from 'node:path';

// Load season stats (pre-fetched by scripts/fetch-season-stats.cjs)
let seasonStatsData: Record<string, any> = {};
try {
  const seasonPath = path.join(process.cwd(), 'public/data/season-stats.json');
  seasonStatsData = JSON.parse(fs.readFileSync(seasonPath, 'utf8'));
} catch {
  // No season stats available yet
}

// Load CTF activity data (monthly match counts)
let activityCtfData: Array<{ month: string; games: number }> = [];
try {
  const activityPath = path.join(process.cwd(), 'public/data/activity-ctf.json');
  activityCtfData = JSON.parse(fs.readFileSync(activityPath, 'utf8'));
} catch {
  // No activity data available yet
}

// Load player registry for name lookups (API returns current Steam names which may differ)
let registryNameMap: Record<string, string> = {};
try {
  const registryPath = path.join(process.cwd(), 'src/data/player-registry.json');
  const registry = JSON.parse(fs.readFileSync(registryPath, 'utf8'));
  const entries = registry.players || [];
  registryNameMap = Object.fromEntries(entries.map((p: { steamId: string; name: string }) => [p.steamId, p.name]));
} catch {
  // Registry not available
}

// Get all data for client-side comparison (filter out unpublished)
const allPlayers = await getCollection('players');
const players = allPlayers.filter(p => p.data.published !== false);
const mice = await getCollection('mice');
const mousepads = await getCollection('mousepads');
const keyboards = await getCollection('keyboards');
const monitors = await getCollection('monitors');
const headsets = await getCollection('headsets');

// Create lookup maps
const miceMap = Object.fromEntries(mice.map(m => [m.id, m.data]));
const mousepadsMap = Object.fromEntries(mousepads.map(m => [m.id, m.data]));
const keyboardsMap = Object.fromEntries(keyboards.map(k => [k.id, k.data]));
const monitorsMap = Object.fromEntries(monitors.map(m => [m.id, m.data]));
const headsetsMap = Object.fromEntries(headsets.map(h => [h.id, h.data]));

// Prepare player data for client
const playersData = Object.fromEntries(
  players.map(p => [p.id, {
    ...p.data,
    id: p.id,
    mouseData: miceMap[p.data.mouse] || null,
    mousepadData: mousepadsMap[p.data.mousepad] || null,
    keyboardData: keyboardsMap[p.data.keyboard] || null,
    monitorData: monitorsMap[p.data.monitor] || null,
    headsetData: headsetsMap[p.data.headset] || null,
  }])
);

const sortedPlayers = players.sort((a, b) => a.data.name.localeCompare(b.data.name));

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Quake Live Player Comparison Tool",
  "description": "Compare settings and hardware between Quake Live players",
  "url": "https://stripyq.github.io/quakesettings/compare/",
  "applicationCategory": "GameApplication"
};
---

<BaseLayout title="Compare Players" description="Compare settings and hardware between Quake Live players side-by-side. See sensitivity, keybinds, crosshairs, and gear differences." schema={schema} ogImage="/images/og/compare.jpg">
  <div class="page-header">
    <h1>Compare Players</h1>
    <p>Select two players to compare their settings side by side</p>
  </div>

  <div class="compare-selectors">
    <div class="selector-group">
      <label for="player1">Player 1</label>
      <select id="player1">
        <option value="">Select a player...</option>
        {sortedPlayers.map(p => (
          <option value={p.id}>{p.data.name}</option>
        ))}
      </select>
    </div>
    <div class="vs-badge">VS</div>
    <div class="selector-group">
      <label for="player2">Player 2</label>
      <select id="player2">
        <option value="">Select a player...</option>
        {sortedPlayers.map(p => (
          <option value={p.id}>{p.data.name}</option>
        ))}
      </select>
    </div>
  </div>

  <div id="comparison-container" class="comparison-container hidden">
    <table class="compare-table">
      <thead>
        <tr>
          <th class="label-header">Setting</th>
          <th id="p1-header" class="player-header">Player 1</th>
          <th id="p2-header" class="player-header">Player 2</th>
        </tr>
      </thead>
      <tbody id="compare-body">
        <!-- Populated by JavaScript -->
      </tbody>
    </table>
  </div>

  <div id="hoq-overall-container" class="hoq-overall-container hidden"></div>
  <div id="season-compare-container" class="season-compare-container hidden"></div>
  <div id="h2h-container" class="h2h-container hidden"></div>
  <div id="matchup-history-container" class="matchup-history-container hidden"></div>
  <div id="hoq-history-container" class="hoq-history-container hidden" data-activity={JSON.stringify(activityCtfData)}></div>
  <div id="rivalries-container" class="rivalries-container hidden"></div>
  <div id="race-compare-container" class="race-compare-container hidden"></div>

  <div id="empty-state" class="empty-state">
    <p>Select two players above to compare their settings</p>
  </div>

  <script define:vars={{ playersData, base, seasonStatsData, registryNameMap }}>
    document.addEventListener('DOMContentLoaded', function() {
      const player1Select = document.getElementById('player1');
      const player2Select = document.getElementById('player2');
      const comparisonContainer = document.getElementById('comparison-container');
      const emptyState = document.getElementById('empty-state');
      const compareBody = document.getElementById('compare-body');
      const p1Header = document.getElementById('p1-header');
      const p2Header = document.getElementById('p2-header');
      const hoqOverallContainer = document.getElementById('hoq-overall-container');
      const h2hContainer = document.getElementById('h2h-container');
      const matchupHistoryContainer = document.getElementById('matchup-history-container');
      const seasonCompareContainer = document.getElementById('season-compare-container');
      const rivalriesContainer = document.getElementById('rivalries-container');
      const raceCompareContainer = document.getElementById('race-compare-container');
      const hoqHistoryContainer = document.getElementById('hoq-history-container');

      // Check URL params for pre-selected players
      const urlParams = new URLSearchParams(window.location.search);
      const p1Param = urlParams.get('p1');
      const p2Param = urlParams.get('p2');

      if (p1Param && playersData[p1Param]) {
        player1Select.value = p1Param;
      }
      if (p2Param && playersData[p2Param]) {
        player2Select.value = p2Param;
      }

      function formatValue(val, isNumeric = false, decimals = 0) {
        if (val === null || val === undefined || val === '' || val === 'Unknown') return '';
        if (isNumeric && typeof val === 'number') {
          return decimals > 0 ? val.toFixed(decimals) : val.toString();
        }
        return val;
      }

      function formatRating(num) {
        if (num === null || num === undefined) return '';
        // Remove trailing zeros after decimal (22.00 → 22, 22.50 → 22.5, 25.26 → 25.26)
        return parseFloat(Number(num).toFixed(2)).toString();
      }

      // cm/360 calculation - two modes:
      // 1. Standard (m_cpi = 0): cm/360 = (360 / (m_yaw × dpi × sens)) × 2.54
      // 2. With m_cpi > 0: cm/360 = (360 / sens) × (m_cpi / dpi)
      // Sources:
      //   https://funender.com/quake/mouse/index.html
      //   https://www.esreality.com/post/2256180/re-mouse-sensitivity/
      function formatCm360(player) {
        let val;
        if (player.dpi && player.sensitivity) {
          if (player.m_cpi && player.m_cpi > 0) {
            val = (360 / player.sensitivity) * (player.m_cpi / player.dpi);
          } else {
            const yaw = player.m_yaw || 0.022;
            val = (360 / (yaw * player.dpi * player.sensitivity)) * 2.54;
          }
        } else {
          val = player.cm360 || 0;
        }
        const fixed = val.toFixed(2);
        return fixed.endsWith('.00') ? Math.round(val).toString() : fixed;
      }

      // Real Accel calculation — normalizes acceleration across different DPI settings
      // Formula (style 0/legacy): ((dpi × windowsSens / 2.54)² × m_yaw × accelValue) / 1000
      // Source: https://funender.com/quake/mouse/index.html
      function calculateRealAccel(player) {
        if (!player.acceleration || !player.accelValue || player.accelValue <= 0) return null;
        if (!player.dpi) return null;
        if (player.accelStyle === 1) return null;
        const yaw = player.m_yaw || 0.022;
        const windowsSens = player.rawInput ? 1 : (player.windowsSensitivity || 1);
        const dpiTerm = (player.dpi * windowsSens) / 2.54;
        const realAccel = (Math.pow(dpiTerm, 2) * yaw * player.accelValue) / 1000;
        return Math.round(realAccel * 100) / 100;
      }

      function formatRealAccel(val) {
        if (val === null) return '';
        const fixed = val.toFixed(2);
        return fixed.endsWith('.00') ? Math.round(val).toString() : fixed;
      }

      function formatBind(val) {
        if (!val) return '';
        return String(val).toUpperCase();
      }

      function countryCodeToFlag(code) {
        if (!code || code.length !== 2) return '';
        return code
          .toUpperCase()
          .split('')
          .map(char => String.fromCodePoint(127397 + char.charCodeAt(0)))
          .join('');
      }

      function radarChartRow(p1, p2) {
        const hasAny = p1.accuracy_rg != null || p2.accuracy_rg != null ||
                        p1.accuracy_lg != null || p2.accuracy_lg != null ||
                        p1.accuracy_rl != null || p2.accuracy_rl != null;
        if (!hasAny) return '';

        // 6 axes: hexagon layout - weapons grouped, then other stats
        const axes = [
          { label: 'RG', angle: 90 },
          { label: 'LG', angle: 30 },
          { label: 'RL', angle: -30 },
          { label: 'cm/360\u00b0', angle: -90 },
          { label: 'Games', angle: -150 },
          { label: 'Rating', angle: 150 }
        ];
        const cx = 160, cy = 155, outerR = 100;

        function polarToCart(angleDeg, r) {
          const rad = angleDeg * Math.PI / 180;
          return { x: cx + r * Math.cos(rad), y: cy - r * Math.sin(rad) };
        }

        function getCm360Raw(player) {
          if (player.dpi && player.sensitivity) {
            if (player.m_cpi && player.m_cpi > 0) {
              return (360 / player.sensitivity) * (player.m_cpi / player.dpi);
            }
            const yaw = player.m_yaw || 0.022;
            return (360 / (yaw * player.dpi * player.sensitivity)) * 2.54;
          }
          return player.cm360 || null;
        }

        function getRating(player) {
          return player.ctfRating || player.tdmRating || null;
        }

        function getTotalGames(player) {
          const ctf = player.ctfGames || 0;
          const tdm = player.tdmGames || 0;
          return ctf + tdm;
        }

        function getPlayerValues(player) {
          const rg = player.accuracy_rg || 0;
          const lg = player.accuracy_lg || 0;
          const rl = player.accuracy_rl || 0;

          const cm360 = getCm360Raw(player);
          const cm360Norm = cm360 != null
            ? Math.max(0, Math.min(100, ((70 - cm360) / 60) * 100))
            : 50;

          const games = getTotalGames(player);
          const gamesNorm = Math.min(100, (games / 2000) * 100);

          const rating = getRating(player);
          const ratingNorm = rating != null
            ? Math.max(0, Math.min(100, ((rating - 15) / 35) * 100))
            : 50;

          return [rg, lg, rl, cm360Norm, gamesNorm, ratingNorm];
        }

        // Grid rings
        let gridSvg = '';
        [20, 40, 60, 80, 100].forEach(pct => {
          const r = (pct / 100) * outerR;
          const pts = axes.map(a => {
            const p = polarToCart(a.angle, r);
            return p.x + ',' + p.y;
          }).join(' ');
          gridSvg += '<polygon points="' + pts + '" fill="none" stroke="#374151" stroke-width="1"/>';
        });

        // Axis lines + labels
        let axesSvg = '';
        axes.forEach(a => {
          const outer = polarToCart(a.angle, outerR);
          axesSvg += '<line x1="' + cx + '" y1="' + cy + '" x2="' + outer.x + '" y2="' + outer.y + '" stroke="#374151" stroke-width="1"/>';
          const labelPos = polarToCart(a.angle, outerR + 18);
          axesSvg += '<text x="' + labelPos.x + '" y="' + labelPos.y + '" fill="#d1d5db" font-size="12" font-weight="600" text-anchor="middle" dominant-baseline="central">' + a.label + '</text>';
        });

        // Tick labels on the RG axis (top)
        let tickSvg = '';
        [20, 40, 60, 80, 100].forEach(pct => {
          const r = (pct / 100) * outerR;
          const p = polarToCart(90, r);
          tickSvg += '<text x="' + (p.x + 14) + '" y="' + p.y + '" fill="#6b7280" font-size="9" text-anchor="start" dominant-baseline="central">' + pct + '</text>';
        });

        // Player polygons (P2 uses dashed stroke for distinction)
        function playerPoly(player, color, dashed) {
          const values = getPlayerValues(player);
          const pts = values.map((val, i) => {
            const r = (val / 100) * outerR;
            const p = polarToCart(axes[i].angle, r);
            return p.x + ',' + p.y;
          }).join(' ');
          const dashAttr = dashed ? ' stroke-dasharray="6,3"' : '';
          return '<polygon points="' + pts + '" fill="' + color + '" fill-opacity="0.35" stroke="' + color + '" stroke-width="3"' + dashAttr + '/>';
        }

        // Player dots
        function playerDots(player, color) {
          const values = getPlayerValues(player);
          let dots = '';
          values.forEach((val, i) => {
            const r = (val / 100) * outerR;
            const p = polarToCart(axes[i].angle, r);
            dots += '<circle cx="' + p.x + '" cy="' + p.y + '" r="5" fill="' + color + '"/>';
          });
          return dots;
        }

        const p1Color = '#3b82f6';
        const p2Color = '#a855f7';

        const svgContent = gridSvg + axesSvg + tickSvg +
          playerPoly(p1, p1Color, false) +
          playerPoly(p2, p2Color, true) +
          playerDots(p1, p1Color) +
          playerDots(p2, p2Color);

        // Chart row: legend above, then chart
        let html = '<tr class="data-row"><td colspan="3" class="radar-cell">' +
          '<div class="radar-chart-wrapper">' +
          '<div class="radar-legend">' +
          '<span class="radar-legend-item"><span class="radar-swatch" style="background:' + p1Color + '"></span>' + p1.name + '</span>' +
          '<span class="radar-legend-item"><span class="radar-swatch" style="background:' + p2Color + '"></span>' + p2.name + '</span>' +
          '</div>' +
          '<svg viewBox="0 0 320 310" width="320" height="310" xmlns="http://www.w3.org/2000/svg">' +
          svgContent + '</svg>' +
          '</div></td></tr>';

        // Accuracy value rows only (cm/360° and Rating already shown elsewhere)
        html += compareRow('RG', p1.accuracy_rg != null ? p1.accuracy_rg + '%' : '', p2.accuracy_rg != null ? p2.accuracy_rg + '%' : '', true);
        html += compareRow('LG', p1.accuracy_lg != null ? p1.accuracy_lg + '%' : '', p2.accuracy_lg != null ? p2.accuracy_lg + '%' : '', true);
        html += compareRow('RL', p1.accuracy_rl != null ? p1.accuracy_rl + '%' : '', p2.accuracy_rl != null ? p2.accuracy_rl + '%' : '', true);

        return html;
      }

      function updateComparison() {
        const p1Id = player1Select.value;
        const p2Id = player2Select.value;

        if (!p1Id || !p2Id) {
          comparisonContainer.classList.add('hidden');
          hoqOverallContainer.classList.add('hidden');
          h2hContainer.classList.add('hidden');
          seasonCompareContainer.classList.add('hidden');
          rivalriesContainer.classList.add('hidden');
          raceCompareContainer.classList.add('hidden');
          hoqHistoryContainer.classList.add('hidden');
          emptyState.classList.remove('hidden');
          return;
        }

        const p1 = playersData[p1Id];
        const p2 = playersData[p2Id];

        if (!p1 || !p2) return;

        comparisonContainer.classList.remove('hidden');
        emptyState.classList.add('hidden');

        // Update URL
        const newUrl = `${window.location.pathname}?p1=${p1Id}&p2=${p2Id}`;
        window.history.replaceState({}, '', newUrl);

        // Update headers with flag emojis
        const p1Country = p1.country && p1.country !== 'Unknown' ? p1.country : '';
        const p2Country = p2.country && p2.country !== 'Unknown' ? p2.country : '';
        const p1Flag = countryCodeToFlag(p1Country);
        const p2Flag = countryCodeToFlag(p2Country);

        p1Header.innerHTML = `<span class="header-name">${p1.name}</span>${p1Flag ? `<span class="header-country">${p1Flag}</span>` : ''}`;
        p2Header.innerHTML = `<span class="header-name">${p2.name}</span>${p2Flag ? `<span class="header-country">${p2Flag}</span>` : ''}`;

        // Build comparison table
        let html = '';

        // Team row (show if at least one player has a team)
        if (p1.team2026 || p2.team2026) {
          html += compareRow('Team', p1.team2026 || '', p2.team2026 || '');
        }

        // Section: Mouse Settings
        html += sectionHeader('Mouse Settings');
        html += compareRow('cm/360', formatCm360(p1), formatCm360(p2), true);
        html += compareRow('Acceleration',
          p1.acceleration ? (p1.accelValue ? String(p1.accelValue) : 'On') : 'Off',
          p2.acceleration ? (p2.accelValue ? String(p2.accelValue) : 'On') : 'Off');

        // Show Real Accel row if either player uses accel
        const p1RealAccel = calculateRealAccel(p1);
        const p2RealAccel = calculateRealAccel(p2);
        if (p1RealAccel !== null || p2RealAccel !== null) {
          html += compareRow('Real Accel', formatRealAccel(p1RealAccel), formatRealAccel(p2RealAccel), true);
        }

        html += compareRow('eDPI', p1.edpi, p2.edpi, true);
        html += compareRow('Sensitivity', p1.sensitivity, p2.sensitivity, true);
        html += compareRow('DPI', p1.dpi, p2.dpi, true);
        html += compareRow('m_yaw', formatValue(p1.m_yaw), formatValue(p2.m_yaw));

        // Section: Mouse Hardware
        html += sectionHeader('Mouse Hardware');
        html += compareHardwareRow('Mouse', p1.mouseData, p2.mouseData);
        html += compareRow('Mouse Shape', formatValue(p1.mouseData?.shape), formatValue(p2.mouseData?.shape));
        html += compareRow('Grip Style', formatValue(p1.grip), formatValue(p2.grip));
        html += compareHardwareRow('Mousepad', p1.mousepadData, p2.mousepadData);
        html += compareRow('Skates', formatValue(p1.skates), formatValue(p2.skates));

        // Section: Game Settings
        html += sectionHeader('Game Settings');
        html += compareRow('FOV', p1.fov, p2.fov, true);
        html += compareRow('Crosshair', formatValue(p1.crosshair), formatValue(p2.crosshair));
        html += compareRow('Enemy Model', formatValue(p1.enemyModel), formatValue(p2.enemyModel));

        // Section: Key Bindings
        html += sectionHeader('Key Bindings');
        html += compareRow('Forward', formatBind(p1.forward), formatBind(p2.forward));
        html += compareRow('Back', formatBind(p1.back), formatBind(p2.back));
        html += compareRow('Left', formatBind(p1.left), formatBind(p2.left));
        html += compareRow('Right', formatBind(p1.right), formatBind(p2.right));
        html += compareRow('Jump', formatBind(p1.jump), formatBind(p2.jump));
        html += compareRow('Fire', formatBind(p1.attack), formatBind(p2.attack));
        html += compareRow('Zoom', formatBind(p1.zoom), formatBind(p2.zoom));
        html += compareRow('Crouch', formatBind(p1.crouch), formatBind(p2.crouch));

        // Section: Other Hardware
        html += sectionHeader('Other Hardware');
        html += compareHardwareRow('Keyboard', p1.keyboardData, p2.keyboardData);
        html += compareHardwareRow('Monitor', p1.monitorData, p2.monitorData);
        html += compareHardwareRow('Headset', p1.headsetData, p2.headsetData);

        // Section: Ratings (only show if at least one player has data)
        const hasRatings = p1.duelRating || p2.duelRating || p1.tdmRating || p2.tdmRating || p1.ctfRating || p2.ctfRating;
        if (hasRatings) {
          html += sectionHeader('Ratings');
          if (p1.duelRating || p2.duelRating) {
            html += compareRow('Duel', formatRating(p1.duelRating), formatRating(p2.duelRating), true);
          }
          if (p1.tdmRating || p2.tdmRating) {
            html += compareRow('TDM', formatRating(p1.tdmRating), formatRating(p2.tdmRating), true);
          }
          if (p1.ctfRating || p2.ctfRating) {
            html += compareRow('CTF', formatRating(p1.ctfRating), formatRating(p2.ctfRating), true);
          }
        }

        compareBody.innerHTML = html;
        updateHoqOverall(p1, p2);
        updateH2H(p1, p2);
        updateMatchupHistory(p1, p2);
        updateSeasonCompare(p1, p2);
        updateRivalries(p1, p2);
        updateRaceCompare(p1, p2);
      }

      // Helper: get mode-specific stats for a player (supports both nested and legacy flat format)
      function getModeStats(steamId, mode) {
        var entry = seasonStatsData[steamId];
        if (!entry) return null;
        // New nested format: entry.ctf / entry.tdm
        if (entry[mode]) return entry[mode];
        // Legacy flat format: career/weapons at top level (treat as ctf)
        if (mode === 'ctf' && entry.career) return entry;
        return null;
      }

      function fmtNum(n) {
        if (n == null) return null;
        return n.toLocaleString();
      }

      function updateHoqOverall(p1, p2) {
        hoqOverallContainer.classList.add('hidden');
        hoqOverallContainer.innerHTML = '';

        const hasHoq = p1.favorite_map || p2.favorite_map || p1.accuracy_rg || p2.accuracy_rg;
        if (!hasHoq) return;

        let hoqHtml = '<div class="cmp-section-heading">HoQ Stats</div>';
        hoqHtml += '<table class="compare-table hoq-overall-table"><thead><tr>';
        hoqHtml += '<th class="label-header">Stat</th>';
        hoqHtml += '<th class="player-header"><span class="header-name">' + p1.name + '</span></th>';
        hoqHtml += '<th class="player-header"><span class="header-name">' + p2.name + '</span></th>';
        hoqHtml += '</tr></thead><tbody>';
        hoqHtml += compareRow('Favorite Map', p1.favorite_map || '\u2014', p2.favorite_map || '\u2014');
        hoqHtml += compareRow('Favorite Gametype', p1.favorite_gametype || '\u2014', p2.favorite_gametype || '\u2014');
        hoqHtml += compareRow('Favorite Weapon', p1.favorite_weapon || '\u2014', p2.favorite_weapon || '\u2014');
        hoqHtml += radarChartRow(p1, p2);
        hoqHtml += '</tbody></table>';
        hoqOverallContainer.innerHTML = hoqHtml;
        hoqOverallContainer.classList.remove('hidden');
      }

      function updateH2H(p1, p2) {
        h2hContainer.classList.add('hidden');
        h2hContainer.innerHTML = '';

        if (!p1.steamId || !p2.steamId) return;

        var cards = '';
        var modes = ['ctf', 'tdm'];
        for (var mi = 0; mi < modes.length; mi++) {
          var mode = modes[mi];
          var modeLabel = mode.toUpperCase();
          var p1ModeStats = getModeStats(p1.steamId, mode);
          var raw = p1ModeStats?.headToHead;
          if (!raw) continue;

          var data = Array.isArray(raw) ? raw : (Array.isArray(raw?.data) ? raw.data : null);
          if (!data) continue;

          var match = data.find(function(entry) {
            return entry.steam_id === p2.steamId || entry.opponent_steam_id === p2.steamId;
          });
          if (!match) continue;

          var p1Kills = match.kills_against != null ? match.kills_against
            : (match.kills != null ? match.kills : match.wins);
          var p2Kills = match.deaths_to != null ? match.deaths_to
            : (match.deaths != null ? match.deaths : match.losses);
          if (p1Kills == null || p2Kills == null) continue;

          var total = p1Kills + p2Kills;
          var p1Pct = total > 0 ? (p1Kills / total) * 100 : 50;
          var winRate = p1Pct.toFixed(1);
          var matchesTogether = match.matches_together || match.games || match.total_games || null;
          var p1Dmg = match.damage_dealt || match.damage || null;
          var p2Dmg = match.damage_received || match.damage_taken || null;

          // Check for detailed matchup data (match W/L when on opposite teams)
          var matchupDetail = p1ModeStats?.headToHeadMatchups?.[p2.steamId];
          // Try reverse lookup if not found
          if (!matchupDetail) {
            var p2ModeStatsH2H = getModeStats(p2.steamId, mode);
            var reverseH2H = p2ModeStatsH2H?.headToHeadMatchups?.[p1.steamId];
            if (reverseH2H?.overall) {
              matchupDetail = {
                overall: {
                  matches_won: reverseH2H.overall.matches_lost || 0,
                  matches_lost: reverseH2H.overall.matches_won || 0,
                  matches_played: reverseH2H.overall.matches_played || 0,
                },
                maps: Array.isArray(reverseH2H.maps) ? reverseH2H.maps.map(function(rm) {
                  return { map: rm.map, matches_won: rm.matches_lost || 0, matches_lost: rm.matches_won || 0, matches_played: rm.matches_played || 0 };
                }) : null,
              };
            }
          }
          var matchRecordHtml = '';
          if (matchupDetail?.overall) {
            var mWon = matchupDetail.overall.matches_won || 0;
            var mLost = matchupDetail.overall.matches_lost || 0;
            var mPlayed = matchupDetail.overall.matches_played || (mWon + mLost);
            if (mPlayed > 0) {
              var mPct = ((mWon / mPlayed) * 100).toFixed(1);
              var mBarW = (mWon / mPlayed) * 100;

              // Best/worst map from detailed matchup data
              var bestWorstHtml = '';
              var mMaps = Array.isArray(matchupDetail.maps) ? matchupDetail.maps : [];
              if (mMaps.length > 0) {
                var mapWithRates = mMaps.filter(function(m) {
                  return ((m.matches_won || 0) + (m.matches_lost || 0)) > 0;
                }).map(function(m) {
                  var mw = m.matches_won || 0;
                  var ml = m.matches_lost || 0;
                  var mp = m.matches_played || (mw + ml);
                  var name = (m.map || '').replace(/^(ctf|tdm)_?/i, '').replace(/_/g, ' ');
                  return { name: name, won: mw, lost: ml, played: mp, rate: mp > 0 ? mw / mp : 0 };
                }).sort(function(a, b) { return b.rate - a.rate; });

                if (mapWithRates.length > 0) {
                  var best = mapWithRates[0];
                  var worst = mapWithRates[mapWithRates.length - 1];
                  bestWorstHtml = '<div class="h2h-match-record-maps">';
                  bestWorstHtml += '<span class="h2h-map-best">Best map: ' + best.name + ' (' + best.won + '-' + best.lost + ')</span>';
                  if (worst !== best) {
                    bestWorstHtml += '<span class="h2h-map-worst">Worst map: ' + worst.name + ' (' + worst.won + '-' + worst.lost + ')</span>';
                  }
                  bestWorstHtml += '</div>';
                }
              }

              // Winning side gets player color; losing side stays neutral
              var mWonClass = mWon > mLost ? ' h2h-p1-color' : '';
              var mLostClass = mLost > mWon ? ' h2h-p2-color' : '';

              matchRecordHtml =
                '<div class="h2h-match-record">' +
                  '<div class="h2h-match-record-label">Match record (when on opposite teams)</div>' +
                  '<div class="h2h-match-record-row">' +
                    '<span class="h2h-match-record-side' + mWonClass + '">' + mWon + 'W</span>' +
                    '<div class="h2h-match-record-bar">' +
                      '<div class="h2h-bar-p1" style="width:' + mBarW + '%"></div>' +
                      '<div class="h2h-bar-p2" style="width:' + (100 - mBarW) + '%"></div>' +
                    '</div>' +
                    '<span class="h2h-match-record-side' + mLostClass + '">' + mLost + 'W</span>' +
                  '</div>' +
                  '<div class="h2h-match-record-meta">' + mPct + '% match win rate \u00b7 ' + mPlayed + ' matches</div>' +
                  bestWorstHtml +
                '</div>';
            }
          }

          // Winning player gets their color on kill count; losing stays neutral
          var p1KillClass = p1Kills >= p2Kills ? ' h2h-p1-color' : '';
          var p2KillClass = p2Kills >= p1Kills ? ' h2h-p2-color' : '';
          if (p1Kills === p2Kills) { p1KillClass = ''; p2KillClass = ''; }

          cards +=
            '<div class="h2h-card">' +
              '<div class="h2h-title">Head to Head \u2013 ' + modeLabel + ' <span class="h2h-season-tag">Season</span></div>' +
              '<div class="h2h-matchup">' +
                '<div class="h2h-side h2h-left">' +
                  '<div class="h2h-player-info h2h-align-right">' +
                    '<span class="h2h-name h2h-p1-color">' + p1.name + '</span>' +
                  '</div>' +
                  '<div class="h2h-stat-block h2h-align-right">' +
                    '<span class="h2h-kill-count' + p1KillClass + '">' + p1Kills + '</span>' +
                    '<span class="h2h-kill-label">kills</span>' +
                    (p1Dmg ? '<span class="h2h-dmg">' + fmtNum(p1Dmg) + ' dmg</span>' : '') +
                  '</div>' +
                '</div>' +
                '<div class="h2h-vs">vs</div>' +
                '<div class="h2h-side h2h-right">' +
                  '<div class="h2h-stat-block h2h-align-left">' +
                    '<span class="h2h-kill-count' + p2KillClass + '">' + p2Kills + '</span>' +
                    '<span class="h2h-kill-label">kills</span>' +
                    (p2Dmg ? '<span class="h2h-dmg">' + fmtNum(p2Dmg) + ' dmg</span>' : '') +
                  '</div>' +
                  '<div class="h2h-player-info h2h-align-left">' +
                    '<span class="h2h-name h2h-p2-color">' + p2.name + '</span>' +
                  '</div>' +
                '</div>' +
              '</div>' +
              '<div class="h2h-bar">' +
                '<div class="h2h-bar-p1" style="width:' + p1Pct + '%"></div>' +
                '<div class="h2h-bar-p2" style="width:' + (100 - p1Pct) + '%"></div>' +
              '</div>' +
              '<div class="h2h-meta">' +
                '<span class="h2h-winrate">' + winRate + '% kill rate for <span class="h2h-p1-color">' + p1.name + '</span></span>' +
                (matchesTogether ? '<span class="h2h-games">' + matchesTogether + ' games together</span>' : '') +
              '</div>' +
              matchRecordHtml +
            '</div>';
        }

        if (!cards) return;
        h2hContainer.innerHTML = '<div class="cmp-section-heading">Head to Head</div>' + cards;
        h2hContainer.classList.remove('hidden');
      }

      function updateMatchupHistory(p1, p2) {
        matchupHistoryContainer.classList.add('hidden');
        matchupHistoryContainer.innerHTML = '';

        if (!p1.steamId || !p2.steamId) {
          console.log('[MatchRecord] No steamIds:', p1.steamId, p2.steamId);
          return;
        }

        var cards = '';
        var modes = ['ctf', 'tdm'];
        for (var mi = 0; mi < modes.length; mi++) {
          var mode = modes[mi];
          var modeLabel = mode.toUpperCase();
          var p1ModeStats = getModeStats(p1.steamId, mode);

          console.log('[MatchRecord ' + mode + '] p1SteamId=' + p1.steamId + ' p2SteamId=' + p2.steamId);
          console.log('[MatchRecord ' + mode + '] p1ModeStats keys:', p1ModeStats ? Object.keys(p1ModeStats) : 'null');
          if (p1ModeStats?.headToHeadMatchups) {
            console.log('[MatchRecord ' + mode + '] headToHeadMatchups keys (first 5):', Object.keys(p1ModeStats.headToHeadMatchups).slice(0, 5));
          }

          // Try both directions: p1's matchups for p2, and p2's matchups for p1
          var matchup = p1ModeStats?.headToHeadMatchups?.[p2.steamId];
          if (!matchup) {
            // Try reverse lookup: maybe the data is stored under p2's entry
            var p2ModeStats = getModeStats(p2.steamId, mode);
            var reverseMatchup = p2ModeStats?.headToHeadMatchups?.[p1.steamId];
            if (reverseMatchup?.overall) {
              console.log('[MatchRecord ' + mode + '] Found via REVERSE lookup (p2 has matchup for p1)');
              // Invert W/L for p1's perspective
              matchup = {
                overall: {
                  matches_won: reverseMatchup.overall.matches_lost || 0,
                  matches_lost: reverseMatchup.overall.matches_won || 0,
                  matches_played: reverseMatchup.overall.matches_played || 0,
                },
                maps: Array.isArray(reverseMatchup.maps) ? reverseMatchup.maps.map(function(m) {
                  return {
                    map: m.map,
                    matches_won: m.matches_lost || 0,
                    matches_lost: m.matches_won || 0,
                    matches_played: m.matches_played || 0,
                  };
                }) : null,
              };
            }
          }

          if (!matchup?.overall) {
            console.log('[MatchRecord ' + mode + '] No matchup data found');
            continue;
          }
          console.log('[MatchRecord ' + mode + '] Found matchup:', JSON.stringify(matchup.overall));

          var overall = matchup.overall;
          var won = overall.matches_won || 0;
          var lost = overall.matches_lost || 0;
          var played = overall.matches_played || (won + lost);
          if (played === 0) continue;

          var winPct = played > 0 ? ((won / played) * 100).toFixed(1) : '0.0';
          var winPctNum = parseFloat(winPct);
          var p1BarW = played > 0 ? (won / played) * 100 : 50;

          // Per-map table
          var mapTableHtml = '';
          var maps = Array.isArray(matchup.maps) ? matchup.maps : [];
          if (maps.length > 0) {
            var sorted = maps.slice().sort(function(a, b) {
              return (b.matches_played || 0) - (a.matches_played || 0);
            });
            var tableRows = '';
            for (var j = 0; j < sorted.length; j++) {
              var m = sorted[j];
              var mWon = m.matches_won || 0;
              var mLost = m.matches_lost || 0;
              var mPlayed = m.matches_played || (mWon + mLost);
              if (mPlayed === 0) continue;
              var mWinPct = mPlayed > 0 ? Math.round((mWon / mPlayed) * 100) : 0;
              var mapName = m.map || 'Unknown';
              var displayName = mapName.replace(/^(ctf|tdm)_?/i, '').replace(/_/g, ' ');

              tableRows +=
                '<tr>' +
                  '<td class="mh-td-map">' + displayName + '</td>' +
                  '<td class="mh-td-num">' + mWon + '</td>' +
                  '<td class="mh-td-num">' + mLost + '</td>' +
                  '<td class="mh-td-num mh-td-pct">' + mWinPct + '%</td>' +
                '</tr>';
            }
            if (tableRows) {
              mapTableHtml =
                '<div class="mh-maps">' +
                  '<div class="mh-maps-label">Per-Map Breakdown</div>' +
                  '<table class="mh-table">' +
                    '<thead><tr>' +
                      '<th class="mh-th-map">Map</th>' +
                      '<th class="mh-th-num h2h-p1-color">' + p1.name + '</th>' +
                      '<th class="mh-th-num h2h-p2-color">' + p2.name + '</th>' +
                      '<th class="mh-th-num">Win%</th>' +
                    '</tr></thead>' +
                    '<tbody>' + tableRows + '</tbody>' +
                  '</table>' +
                '</div>';
            }
          }

          // Insight text based on win rate
          var insightHtml = '';
          if (played >= 3) {
            if (winPctNum < 40) {
              insightHtml = '<div class="mh-insight"><span class="h2h-p2-color">' + p2.name + '</span> dominates <span class="h2h-p1-color">' + p1.name + '</span> when they\u2019re on opposite teams!</div>';
            } else if (winPctNum > 60) {
              insightHtml = '<div class="mh-insight"><span class="h2h-p1-color">' + p1.name + '</span> dominates <span class="h2h-p2-color">' + p2.name + '</span> when they\u2019re on opposite teams!</div>';
            } else {
              insightHtml = '<div class="mh-insight">Evenly matched when on opposite teams</div>';
            }
          }

          cards +=
            '<div class="mh-card">' +
              '<div class="mh-title">Match Record \u2013 ' + modeLabel + ' <span class="mh-season-tag">Season</span></div>' +
              '<div class="mh-subtitle">When on opposite teams</div>' +
              '<div class="mh-overall">' +
                '<div class="mh-record">' +
                  '<span class="mh-record-side">' +
                    '<span class="h2h-p1-color mh-player-label">' + p1.name + '</span>' +
                    '<span class="mh-win-count' + (won > lost ? ' h2h-p1-color' : '') + '">' + won + 'W</span>' +
                  '</span>' +
                  '<span class="mh-record-divider">\u2013</span>' +
                  '<span class="mh-record-side">' +
                    '<span class="mh-win-count' + (lost > won ? ' h2h-p2-color' : '') + '">' + lost + 'W</span>' +
                    '<span class="h2h-p2-color mh-player-label">' + p2.name + '</span>' +
                  '</span>' +
                '</div>' +
                '<div class="mh-bar">' +
                  '<div class="mh-bar-p1" style="width:' + p1BarW + '%"></div>' +
                  '<div class="mh-bar-p2" style="width:' + (100 - p1BarW) + '%"></div>' +
                '</div>' +
                '<div class="mh-meta">' +
                  '<span>' + winPct + '% win rate for <span class="h2h-p1-color">' + p1.name + '</span></span>' +
                  '<span>' + played + ' matches</span>' +
                '</div>' +
              '</div>' +
              mapTableHtml +
              insightHtml +
            '</div>';
        }

        if (!cards) return;
        matchupHistoryContainer.innerHTML = cards;
        matchupHistoryContainer.classList.remove('hidden');
      }

      function updateSeasonCompare(p1, p2) {
        seasonCompareContainer.classList.add('hidden');
        seasonCompareContainer.innerHTML = '';

        if (!p1.steamId && !p2.steamId) return;

        function getVal(obj, keys) {
          if (!obj) return null;
          for (var i = 0; i < keys.length; i++) {
            if (obj[keys[i]] != null) return obj[keys[i]];
          }
          return null;
        }

        function calcWinRate(career) {
          if (!career) return null;
          var w = getVal(career, ['wins', 'total_wins']) || 0;
          var l = getVal(career, ['losses', 'total_losses']) || 0;
          var total = w + l;
          return total > 0 ? ((w / total) * 100).toFixed(1) : null;
        }

        function calcKD(career) {
          if (!career) return null;
          var k = getVal(career, ['kills', 'total_kills']) || 0;
          var d = getVal(career, ['deaths', 'total_deaths']) || 0;
          return d === 0 ? (k > 0 ? 'Perfect' : null) : (k / d).toFixed(2);
        }

        function calcDPM(career) {
          if (!career) return null;
          var dmg = getVal(career, ['damage_dealt', 'total_damage', 'damage']) || 0;
          var time = getVal(career, ['play_time', 'total_play_time', 'time_played']) || 0;
          if (time <= 0) return null;
          return Math.round(dmg / (time / 60));
        }

        function statRow(label, v1, v2, higherBetter) {
          var n1 = parseFloat(v1);
          var n2 = parseFloat(v2);
          var p1Class = '';
          var p2Class = '';
          if (!isNaN(n1) && !isNaN(n2) && n1 !== n2) {
            if (higherBetter) {
              p1Class = n1 > n2 ? 'stat-better' : 'stat-worse';
              p2Class = n2 > n1 ? 'stat-better' : 'stat-worse';
            } else {
              p1Class = n1 < n2 ? 'stat-better' : 'stat-worse';
              p2Class = n2 < n1 ? 'stat-better' : 'stat-worse';
            }
          }
          return '<tr>' +
            '<td class="sc-val ' + p1Class + '">' + v1 + '</td>' +
            '<td class="sc-label">' + label + '</td>' +
            '<td class="sc-val ' + p2Class + '">' + v2 + '</td>' +
          '</tr>';
        }

        var cards = '';
        var modes = ['ctf', 'tdm'];
        for (var mi = 0; mi < modes.length; mi++) {
          var mode = modes[mi];
          var modeLabel = mode.toUpperCase();
          var p1M = getModeStats(p1.steamId, mode);
          var p2M = getModeStats(p2.steamId, mode);

          var p1Career = p1M?.career;
          var p2Career = p2M?.career;
          if (!p1Career && !p2Career) continue;

          var rows = [];

          var p1Games = getVal(p1Career, ['games', 'total_games', 'matches']) || 0;
          var p2Games = getVal(p2Career, ['games', 'total_games', 'matches']) || 0;
          if (p1Games || p2Games) rows.push(['Games', p1Games || '\u2014', p2Games || '\u2014', true]);

          var p1WR = calcWinRate(p1Career);
          var p2WR = calcWinRate(p2Career);
          if (p1WR || p2WR) rows.push(['Win Rate', p1WR ? p1WR + '%' : '\u2014', p2WR ? p2WR + '%' : '\u2014', true]);

          var p1KD = calcKD(p1Career);
          var p2KD = calcKD(p2Career);
          if (p1KD || p2KD) rows.push(['K/D', p1KD || '\u2014', p2KD || '\u2014', true]);

          var p1DPM = calcDPM(p1Career);
          var p2DPM = calcDPM(p2Career);
          if (p1DPM || p2DPM) rows.push(['DPM', p1DPM || '\u2014', p2DPM || '\u2014', true]);

          var p1Kills = getVal(p1Career, ['kills', 'total_kills']) || 0;
          var p2Kills = getVal(p2Career, ['kills', 'total_kills']) || 0;
          if (p1Kills || p2Kills) rows.push(['Kills', p1Kills || '\u2014', p2Kills || '\u2014', true]);

          var p1Streak = getVal(p1Career, ['best_streak', 'best_killstreak', 'kill_streak']) || 0;
          var p2Streak = getVal(p2Career, ['best_streak', 'best_killstreak', 'kill_streak']) || 0;
          if (p1Streak || p2Streak) rows.push(['Best Streak', p1Streak || '\u2014', p2Streak || '\u2014', true]);

          // Flag stats (CTF only)
          var flagRows = '';
          if (mode === 'ctf') {
            var p1Flags = p1M?.flagStats?.data || p1M?.flagStats;
            var p2Flags = p2M?.flagStats?.data || p2M?.flagStats;
            var p1Caps = getVal(p1Flags, ['captures', 'flag_captures', 'total_captures']) || 0;
            var p2Caps = getVal(p2Flags, ['captures', 'flag_captures', 'total_captures']) || 0;
            var p1Rets = getVal(p1Flags, ['returns', 'flag_returns', 'total_returns']) || 0;
            var p2Rets = getVal(p2Flags, ['returns', 'flag_returns', 'total_returns']) || 0;
            var hasFlags = p1Caps || p2Caps || p1Rets || p2Rets;
            if (hasFlags) {
              if (p1Caps || p2Caps) flagRows += statRow('Captures', p1Caps || '\u2014', p2Caps || '\u2014', true);
              if (p1Rets || p2Rets) flagRows += statRow('Returns', p1Rets || '\u2014', p2Rets || '\u2014', true);
            }
          }

          if (rows.length === 0 && !flagRows) continue;

          var tableRows = '';
          for (var ri = 0; ri < rows.length; ri++) {
            tableRows += statRow(rows[ri][0], rows[ri][1], rows[ri][2], rows[ri][3]);
          }

          cards +=
            '<div class="sc-card">' +
              '<div class="sc-title">' + modeLabel + ' Season Stats <span class="sc-season-tag">2026 S1</span></div>' +
              '<table class="sc-table">' +
                '<thead><tr>' +
                  '<th class="sc-th-player h2h-p1-color">' + p1.name + '</th>' +
                  '<th class="sc-th-label"></th>' +
                  '<th class="sc-th-player h2h-p2-color">' + p2.name + '</th>' +
                '</tr></thead>' +
                '<tbody>' + tableRows + '</tbody>' +
                (flagRows ? '<tbody class="sc-flag-section"><tr><td colspan="3" class="sc-section-label">Flag Stats</td></tr>' + flagRows + '</tbody>' : '') +
              '</table>' +
            '</div>';
        }

        seasonCompareContainer.innerHTML = '<div class="cmp-section-heading">HoQ Season Stats</div>' + cards;
        seasonCompareContainer.classList.remove('hidden');
      }

      function updateRivalries(p1, p2) {
        rivalriesContainer.classList.add('hidden');
        rivalriesContainer.innerHTML = '';

        if (!p1.steamId || !p2.steamId) return;

        function rivalryEntry(label, data) {
          if (!data) return '<div class="rv-entry"><span class="rv-type">' + label + '</span><span class="rv-unknown">\u2014</span></div>';
          var opponentId = data.opponent_steam_id || data.steam_id;
          var name = (opponentId && registryNameMap[opponentId]) || data.name || data.opponent_name || '???';
          var kd = data.kd_ratio != null ? parseFloat(data.kd_ratio).toFixed(2) : null;
          return '<div class="rv-entry">' +
            '<span class="rv-type">' + label + '</span>' +
            '<span class="rv-name">' + name + '</span>' +
            (kd ? '<span class="rv-kd">' + kd + ' K/D</span>' : '') +
          '</div>';
        }

        var cards = '';
        var modes = ['ctf', 'tdm'];
        for (var mi = 0; mi < modes.length; mi++) {
          var mode = modes[mi];
          var modeLabel = mode.toUpperCase();
          var p1M = getModeStats(p1.steamId, mode);
          var p2M = getModeStats(p2.steamId, mode);

          var p1Nem = p1M?.nemesis?.data || p1M?.nemesis;
          var p2Nem = p2M?.nemesis?.data || p2M?.nemesis;
          var p1Vic = p1M?.favoriteVictim?.data || p1M?.favoriteVictim;
          var p2Vic = p2M?.favoriteVictim?.data || p2M?.favoriteVictim;

          if (!p1Nem && !p2Nem && !p1Vic && !p2Vic) continue;

          cards +=
            '<div class="rv-card">' +
              '<div class="rv-title">' + modeLabel + ' Rivalries <span class="rv-season-tag">Season</span></div>' +
              '<div class="rv-col-headers">' +
                '<span class="h2h-p1-color rv-col-header">' + p1.name + '</span>' +
                '<span class="h2h-p2-color rv-col-header">' + p2.name + '</span>' +
              '</div>' +
              '<div class="rv-columns">' +
                '<div class="rv-col rv-col-left">' +
                  rivalryEntry('Nemesis', p1Nem) +
                  '<div class="rv-separator"></div>' +
                  rivalryEntry('Favorite Victim', p1Vic) +
                '</div>' +
                '<div class="rv-divider"></div>' +
                '<div class="rv-col rv-col-right">' +
                  rivalryEntry('Nemesis', p2Nem) +
                  '<div class="rv-separator"></div>' +
                  rivalryEntry('Favorite Victim', p2Vic) +
                '</div>' +
              '</div>' +
            '</div>';
        }

        if (!cards) return;
        rivalriesContainer.innerHTML = '<div class="cmp-section-heading">Rivalries</div>' + cards;
        rivalriesContainer.classList.remove('hidden');
      }

      function updateRaceCompare(p1, p2) {
        raceCompareContainer.classList.add('hidden');
        raceCompareContainer.innerHTML = '';

        var r1 = p1.qlrace;
        var r2 = p2.qlrace;

        console.log('[Race H2H] p1.qlrace:', r1 ? ('mode=' + r1.mode + ' top_maps=' + (r1.top_maps ? r1.top_maps.length : 'none')) : 'null');
        console.log('[Race H2H] p2.qlrace:', r2 ? ('mode=' + r2.mode + ' top_maps=' + (r2.top_maps ? r2.top_maps.length : 'none')) : 'null');

        // Need both players to have qlrace data with top_maps
        if (!r1 || !r2 || !r1.top_maps || !r2.top_maps) return;

        // Different modes: show a message
        if (r1.mode !== r2.mode) {
          var m1Label = r1.mode === 2 ? 'VQL Weapons' : 'VQL Strafe';
          var m2Label = r2.mode === 2 ? 'VQL Weapons' : 'VQL Strafe';
          raceCompareContainer.innerHTML = '<div class="cmp-section-heading">Race Head to Head</div>' +
            '<div class="race-h2h-card">' +
            '<p class="race-h2h-empty">Cannot compare — ' + p1.name + ' plays ' + m1Label + ' while ' + p2.name + ' plays ' + m2Label + '.</p>' +
            '</div>';
          raceCompareContainer.classList.remove('hidden');
          return;
        }

        // Find shared maps
        var r2MapIndex = {};
        for (var i = 0; i < r2.top_maps.length; i++) {
          r2MapIndex[r2.top_maps[i].map] = r2.top_maps[i];
        }

        var sharedMaps = [];
        for (var j = 0; j < r1.top_maps.length; j++) {
          var m1 = r1.top_maps[j];
          var m2 = r2MapIndex[m1.map];
          if (m2) {
            sharedMaps.push({ map: m1.map, p1: m1, p2: m2 });
          }
        }

        if (sharedMaps.length === 0) {
          var modeLabel0 = r1.mode === 2 ? 'VQL Weapons' : 'VQL Strafe';
          raceCompareContainer.innerHTML = '<div class="cmp-section-heading">Race Head to Head</div>' +
            '<div class="race-h2h-card">' +
            '<p class="race-h2h-empty">No shared race maps between ' + p1.name + ' (' + r1.top_maps.length + ' maps) and ' + p2.name + ' (' + r2.top_maps.length + ' maps).</p>' +
            '</div>';
          raceCompareContainer.classList.remove('hidden');
          return;
        }

        function fmtTime(ms) {
          var totalSec = ms / 1000;
          var min = Math.floor(totalSec / 60);
          var sec = totalSec % 60;
          return min + ':' + (sec < 10 ? '0' : '') + sec.toFixed(3);
        }

        function fmtDelta(ms) {
          var sec = Math.abs(ms) / 1000;
          return (ms > 0 ? '+' : '-') + sec.toFixed(3) + 's';
        }

        var modeLabel = r1.mode === 2 ? 'VQL Weapons' : 'VQL Strafe';
        var html = '<div class="cmp-section-heading">Race Head to Head</div>' +
          '<div class="race-h2h-card">' +
          '<span class="race-h2h-mode">' + modeLabel + '</span>' +
          '<table class="race-h2h-table">' +
          '<thead><tr>' +
            '<th>Map</th>' +
            '<th class="h2h-p1-color">' + p1.name + '</th>' +
            '<th class="h2h-p2-color">' + p2.name + '</th>' +
            '<th>Delta</th>' +
          '</tr></thead><tbody>';

        for (var k = 0; k < sharedMaps.length; k++) {
          var sm = sharedMaps[k];
          var delta = sm.p1.time - sm.p2.time;
          var p1Faster = delta < 0;
          var p2Faster = delta > 0;

          html += '<tr>' +
            '<td class="race-h2h-map">' + sm.map + '</td>' +
            '<td class="' + (p1Faster ? 'race-faster' : '') + '">' +
              '<span class="race-h2h-time">' + fmtTime(sm.p1.time) + '</span>' +
              '<span class="race-h2h-rank">' + sm.p1.rank + '/' + sm.p1.total + '</span>' +
            '</td>' +
            '<td class="' + (p2Faster ? 'race-faster' : '') + '">' +
              '<span class="race-h2h-time">' + fmtTime(sm.p2.time) + '</span>' +
              '<span class="race-h2h-rank">' + sm.p2.rank + '/' + sm.p2.total + '</span>' +
            '</td>' +
            '<td class="race-h2h-delta">' + (delta === 0 ? 'Tied' : fmtDelta(delta)) + '</td>' +
          '</tr>';
        }

        html += '</tbody></table></div>';
        raceCompareContainer.innerHTML = html;
        raceCompareContainer.classList.remove('hidden');
      }

      // ── HoQ Live Sections ──
      var HOQ_LOCAL = base + 'data/hoq/';
      let hoqAbort = null;

      function updateHoqSections() {
        const p1Id = player1Select.value;
        const p2Id = player2Select.value;
        if (!p1Id || !p2Id || !playersData[p1Id] || !playersData[p2Id]) {
          hoqHistoryContainer.classList.add('hidden');
          return;
        }
        const p1 = playersData[p1Id];
        const p2 = playersData[p2Id];
        const sid1 = p1.steamId;
        const sid2 = p2.steamId;

        if (!sid1 && !sid2) {
          hoqHistoryContainer.classList.add('hidden');
          return;
        }

        if (hoqAbort) hoqAbort.abort();
        const ctrl = new AbortController();
        hoqAbort = ctrl;

        // ── Rating History Chart ──
        hoqHistoryContainer.classList.remove('hidden');
        hoqHistoryContainer.innerHTML =
          '<div class="cmp-section-heading">Rating History</div>' +
          '<div class="hoq-cmp-controls" id="hoq-cmp-controls">' +
            '<div class="hoq-cmp-btn-group">' +
              '<button class="hoq-cmp-mode-btn active" data-mode="ctf">CTF</button>' +
              '<button class="hoq-cmp-mode-btn" data-mode="tdm">TDM</button>' +
            '</div>' +
            '<div class="hoq-cmp-btn-group" id="hoq-cmp-range-controls">' +
              '<button class="hoq-cmp-mode-btn active" data-range="all">All Time</button>' +
              '<button class="hoq-cmp-mode-btn" data-range="year">1 Year</button>' +
              '<button class="hoq-cmp-mode-btn" data-range="month">1 Month</button>' +
              '<button class="hoq-cmp-mode-btn" data-range="week">1 Week</button>' +
            '</div>' +
          '</div>' +
          '<div class="hoq-cmp-chart-wrap">' +
            '<div class="hoq-cmp-loading" id="hoq-cmp-loading">Loading rating history\u2026</div>' +
            '<canvas id="hoq-cmp-canvas" width="800" height="320" style="display:none"></canvas>' +
            '<div class="hoq-cmp-note" id="hoq-cmp-note" style="display:none"></div>' +
            '<div class="hoq-cmp-error" id="hoq-cmp-error" style="display:none"></div>' +
          '</div>';

        // ── Per-Map Win% (appended into season-compare-container) ──
        // Remove any existing map compare slot
        var existingSlot = document.getElementById('hoq-map-cmp-slot');
        if (existingSlot) existingSlot.remove();
        // Ensure the season container is visible with heading
        if (seasonCompareContainer.classList.contains('hidden')) {
          seasonCompareContainer.innerHTML = '<div class="cmp-section-heading">HoQ Season Stats</div>';
          seasonCompareContainer.classList.remove('hidden');
        }
        // Create a slot div to hold the per-map table
        var mapSlot = document.createElement('div');
        mapSlot.id = 'hoq-map-cmp-slot';
        mapSlot.innerHTML =
          '<div class="hoq-cmp-loading" id="hoq-map-cmp-loading">Loading map ratings\u2026</div>' +
          '<table class="hoq-map-cmp-table" id="hoq-map-cmp-table" style="display:none">' +
            '<thead><tr>' +
              '<th>Map</th>' +
              '<th>' + p1.name + ' Win%</th>' +
              '<th>' + p2.name + ' Win%</th>' +
            '</tr></thead>' +
            '<tbody id="hoq-map-cmp-tbody"></tbody>' +
          '</table>' +
          '<div class="hoq-cmp-error" id="hoq-map-cmp-error" style="display:none"></div>';
        seasonCompareContainer.appendChild(mapSlot);

        // Fetch history for both players
        Promise.all([
          sid1 ? fetch(HOQ_LOCAL + sid1 + '/history.json', { signal: ctrl.signal }).then(function(r) { return r.ok ? r.json() : []; }).catch(function() { return []; }) : Promise.resolve([]),
          sid2 ? fetch(HOQ_LOCAL + sid2 + '/history.json', { signal: ctrl.signal }).then(function(r) { return r.ok ? r.json() : []; }).catch(function() { return []; }) : Promise.resolve([]),
        ]).then(function(results) {
          if (ctrl.signal.aborted) return;
          var raw1 = results[0], raw2 = results[1];
          var loading = document.getElementById('hoq-cmp-loading');
          var canvas = document.getElementById('hoq-cmp-canvas');
          var noteEl = document.getElementById('hoq-cmp-note');
          var errorEl = document.getElementById('hoq-cmp-error');
          var controls = document.getElementById('hoq-cmp-controls');

          function parseByMode(raw) {
            var byMode = {};
            var arr = Array.isArray(raw) ? raw : [];
            for (var i = 0; i < arr.length; i++) {
              var e = arr[i];
              var m = e.gametype_short;
              if (!byMode[m]) byMode[m] = [];
              byMode[m].push({ rating: e.rating, date: new Date(e.timestamp * 1000) });
            }
            for (var k in byMode) byMode[k].sort(function(a, b) { return a.date - b.date; });
            return byMode;
          }

          var data1 = parseByMode(raw1);
          var data2 = parseByMode(raw2);
          var hasCtf = (data1['ctf'] && data1['ctf'].length > 0) || (data2['ctf'] && data2['ctf'].length > 0);
          var hasTdm = (data1['tdm'] && data1['tdm'].length > 0) || (data2['tdm'] && data2['tdm'].length > 0);

          if (!hasCtf && !hasTdm) {
            loading.style.display = 'none';
            errorEl.textContent = 'No rating history available for either player.';
            errorEl.style.display = 'block';
            return;
          }

          // Parse CTF activity data from container attribute
          var activityBuckets = [];
          try { activityBuckets = JSON.parse(hoqHistoryContainer.getAttribute('data-activity') || '[]'); } catch(e) {}

          loading.style.display = 'none';
          canvas.style.display = 'block';

          var ctx = canvas.getContext('2d');
          var dpr = window.devicePixelRatio || 1;
          var rect = canvas.getBoundingClientRect();
          canvas.width = rect.width * dpr;
          canvas.height = rect.height * dpr;
          ctx.scale(dpr, dpr);
          var W = rect.width;
          var H = rect.height;

          var P1_COLOR = '#3b82f6';
          var P2_COLOR = '#a855f7';
          var activeMode = hasCtf ? 'ctf' : 'tdm';
          var activeRange = 'all';

          var rangeMsMap = { week: 7*86400000, month: 30*86400000, year: 365*86400000 };
          function filterByRange(arr, range) {
            if (range === 'all' || arr.length === 0) return arr;
            var cutoff = Date.now() - (rangeMsMap[range] || 0);
            return arr.filter(function(d) { return d.date.getTime() >= cutoff; });
          }

          function drawChart(mode) {
            var series1 = filterByRange(data1[mode] || [], activeRange);
            var series2 = filterByRange(data2[mode] || [], activeRange);

            if (series1.length === 0 && series2.length === 0) {
              ctx.clearRect(0, 0, W, H);
              ctx.fillStyle = '#8b949e';
              ctx.font = '13px sans-serif';
              ctx.textAlign = 'center';
              ctx.fillText('No ' + mode.toUpperCase() + ' history for either player.', W / 2, H / 2);
              noteEl.style.display = 'none';
              return;
            }

            var note = '';
            if (!sid1 || series1.length === 0) note = p1.name + ' has no ' + mode.toUpperCase() + ' history.';
            else if (!sid2 || series2.length === 0) note = p2.name + ' has no ' + mode.toUpperCase() + ' history.';
            if (note) { noteEl.textContent = note; noteEl.style.display = 'block'; }
            else { noteEl.style.display = 'none'; }

            var all = series1.concat(series2);
            var allRatings = all.map(function(d) { return d.rating; });
            var minR = Math.min.apply(null, allRatings);
            var maxR = Math.max.apply(null, allRatings);
            var rRange = maxR - minR || 1;
            minR -= rRange * 0.05;
            maxR += rRange * 0.05;
            var allTimes = all.map(function(d) { return d.date.getTime(); });
            var minT = Math.min.apply(null, allTimes);
            var maxT = Math.max.apply(null, allTimes);
            var tRange = maxT - minT || 1;

            var hasActivity = mode === 'ctf' && activityBuckets.length > 0;
            var pad = { top: 30, right: hasActivity ? 50 : 20, bottom: 40, left: 50 };
            var cw = W - pad.left - pad.right;
            var ch = H - pad.top - pad.bottom;

            ctx.clearRect(0, 0, W, H);

            // Legend
            ctx.font = '12px sans-serif';
            ctx.textAlign = 'left';
            ctx.fillStyle = P1_COLOR;
            ctx.fillRect(pad.left, 6, 14, 10);
            ctx.fillText(p1.name, pad.left + 20, 15);
            var p1w = ctx.measureText(p1.name).width;
            ctx.fillStyle = P2_COLOR;
            ctx.fillRect(pad.left + 30 + p1w, 6, 14, 10);
            ctx.fillText(p2.name, pad.left + 50 + p1w, 15);

            // Grid
            ctx.strokeStyle = 'rgba(255,255,255,0.06)';
            ctx.lineWidth = 1;
            var gridSteps = 5;
            for (var i = 0; i <= gridSteps; i++) {
              var y = pad.top + (ch / gridSteps) * i;
              ctx.beginPath();
              ctx.moveTo(pad.left, y);
              ctx.lineTo(pad.left + cw, y);
              ctx.stroke();
            }

            // Y-axis labels
            ctx.fillStyle = '#8b949e';
            ctx.font = '11px monospace';
            ctx.textAlign = 'right';
            for (var i = 0; i <= gridSteps; i++) {
              var val = maxR - ((maxR - minR) / gridSteps) * i;
              var y = pad.top + (ch / gridSteps) * i;
              ctx.fillText(val.toFixed(1), pad.left - 6, y + 4);
            }

            // X-axis labels
            ctx.textAlign = 'center';
            var xLabels = 6;
            for (var i = 0; i < xLabels; i++) {
              var t = minT + (tRange / (xLabels - 1)) * i;
              var d = new Date(t);
              ctx.fillText((d.getMonth() + 1) + '/' + d.getDate(), pad.left + (cw / (xLabels - 1)) * i, H - pad.bottom + 16);
            }

            // Activity bars (CTF only — drawn behind the rating lines)
            if (hasActivity) {
              var visible = activityBuckets.filter(function(b) {
                var parts = b.month.split('-');
                var yr = parseInt(parts[0], 10), mo = parseInt(parts[1], 10);
                var bStart = new Date(yr, mo - 1, 1).getTime();
                var bEnd = new Date(yr, mo, 0, 23, 59, 59).getTime();
                return bEnd >= minT && bStart <= maxT;
              });

              if (visible.length > 0) {
                var maxGames = Math.max.apply(null, visible.map(function(b) { return b.games; }));

                ctx.fillStyle = 'rgba(255,255,255,0.08)';
                for (var vi = 0; vi < visible.length; vi++) {
                  var parts = visible[vi].month.split('-');
                  var yr = parseInt(parts[0], 10), mo = parseInt(parts[1], 10);
                  var bStart = Math.max(new Date(yr, mo - 1, 1).getTime(), minT);
                  var bEnd = Math.min(new Date(yr, mo, 0, 23, 59, 59).getTime(), maxT);

                  var x1 = pad.left + ((bStart - minT) / tRange) * cw;
                  var x2 = pad.left + ((bEnd - minT) / tRange) * cw;
                  var barH = (visible[vi].games / maxGames) * ch;

                  ctx.fillRect(x1, pad.top + ch - barH, x2 - x1, barH);
                }

                // Right Y-axis: games-per-month scale
                ctx.fillStyle = '#666';
                ctx.font = '11px monospace';
                ctx.textAlign = 'left';
                var rightX = pad.left + cw + 6;
                var axisSteps = Math.min(gridSteps, maxGames);
                for (var ai = 0; ai <= axisSteps; ai++) {
                  var val = Math.round((maxGames / axisSteps) * (axisSteps - ai));
                  var y = pad.top + (ch / axisSteps) * ai;
                  ctx.fillText(String(val), rightX, y + 4);
                }
                ctx.font = '9px monospace';
                ctx.fillText('games', rightX, pad.top - 6);
              }
            }

            function drawLine(series, color) {
              if (series.length === 0) return;
              ctx.strokeStyle = color;
              ctx.lineWidth = 2;
              ctx.lineJoin = 'round';
              ctx.beginPath();
              for (var j = 0; j < series.length; j++) {
                var x = pad.left + ((series[j].date.getTime() - minT) / tRange) * cw;
                var y = pad.top + ch - ((series[j].rating - minR) / (maxR - minR)) * ch;
                if (j === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
              }
              ctx.stroke();
            }

            drawLine(series1, P1_COLOR);
            drawLine(series2, P2_COLOR);
          }

          drawChart(activeMode);

          controls.addEventListener('click', function(e) {
            var btn = e.target.closest('.hoq-cmp-mode-btn');
            if (!btn) return;
            if (btn.dataset.mode) {
              activeMode = btn.dataset.mode;
              btn.closest('.hoq-cmp-btn-group').querySelectorAll('.hoq-cmp-mode-btn').forEach(function(b) { b.classList.remove('active'); });
              btn.classList.add('active');
              drawChart(activeMode);
            } else if (btn.dataset.range) {
              activeRange = btn.dataset.range;
              btn.closest('.hoq-cmp-btn-group').querySelectorAll('.hoq-cmp-mode-btn').forEach(function(b) { b.classList.remove('active'); });
              btn.classList.add('active');
              drawChart(activeMode);
            }
          });
        });

        // Fetch map ratings for both players
        Promise.all([
          sid1 ? fetch(HOQ_LOCAL + sid1 + '/map_ratings.json', { signal: ctrl.signal }).then(function(r) { return r.ok ? r.json() : []; }).catch(function() { return []; }) : Promise.resolve([]),
          sid2 ? fetch(HOQ_LOCAL + sid2 + '/map_ratings.json', { signal: ctrl.signal }).then(function(r) { return r.ok ? r.json() : []; }).catch(function() { return []; }) : Promise.resolve([]),
        ]).then(function(results) {
          if (ctrl.signal.aborted) return;
          var raw1 = results[0], raw2 = results[1];
          var loading = document.getElementById('hoq-map-cmp-loading');
          var table = document.getElementById('hoq-map-cmp-table');
          var tbody = document.getElementById('hoq-map-cmp-tbody');
          var errorEl = document.getElementById('hoq-map-cmp-error');

          function toCtfMap(raw) {
            var map = {};
            var arr = Array.isArray(raw) ? raw : [];
            for (var i = 0; i < arr.length; i++) {
              var r = arr[i];
              if (r.gametype_short === 'ctf' && r.games >= 10) map[r.map_name] = r;
            }
            return map;
          }

          var maps1 = toCtfMap(raw1);
          var maps2 = toCtfMap(raw2);
          var seen = {};
          var allMapNames = [];
          var keys1 = Object.keys(maps1);
          var keys2 = Object.keys(maps2);
          for (var i = 0; i < keys1.length; i++) { if (!seen[keys1[i]]) { seen[keys1[i]] = true; allMapNames.push(keys1[i]); } }
          for (var i = 0; i < keys2.length; i++) { if (!seen[keys2[i]]) { seen[keys2[i]] = true; allMapNames.push(keys2[i]); } }

          var rows = allMapNames.map(function(name) {
            return {
              map_name: name,
              p1: maps1[name] || null,
              p2: maps2[name] || null,
              totalGames: (maps1[name] ? maps1[name].games : 0) + (maps2[name] ? maps2[name].games : 0),
            };
          }).sort(function(a, b) { return b.totalGames - a.totalGames; });

          if (rows.length === 0) {
            loading.style.display = 'none';
            errorEl.textContent = 'No CTF map data available for either player.';
            errorEl.style.display = 'block';
            return;
          }

          loading.style.display = 'none';
          table.style.display = 'table';

          function winCls(v) {
            if (v == null) return '';
            if (v > 50) return 'hoq-win-green';
            if (v < 50) return 'hoq-win-red';
            return 'hoq-win-amber';
          }

          for (var i = 0; i < rows.length; i++) {
            var r = rows[i];
            var w1 = r.p1 ? r.p1.win_pct : null;
            var w2 = r.p2 ? r.p2.win_pct : null;
            var w1Str = w1 != null ? w1.toFixed(1) + '%' : '\u2014';
            var w2Str = w2 != null ? w2.toFixed(1) + '%' : '\u2014';
            var cls1 = '';
            var cls2 = '';
            if (w1 != null && w2 != null) {
              if (w1 > w2) cls1 = 'hoq-map-higher';
              else if (w2 > w1) cls2 = 'hoq-map-higher';
            }
            var tr = document.createElement('tr');
            tr.innerHTML =
              '<td>' + r.map_name + '</td>' +
              '<td class="' + winCls(w1) + ' ' + cls1 + '">' + w1Str + '</td>' +
              '<td class="' + winCls(w2) + ' ' + cls2 + '">' + w2Str + '</td>';
            tbody.appendChild(tr);
          }
        });
      }

      player1Select.addEventListener('change', updateHoqSections);
      player2Select.addEventListener('change', updateHoqSections);

      function sectionHeader(title) {
        return `<tr class="section-row"><td colspan="3">${title}</td></tr>`;
      }

      function compareRow(label, val1, val2, isNumeric = false) {
        const v1 = val1 !== undefined && val1 !== null ? String(val1) : '';
        const v2 = val2 !== undefined && val2 !== null ? String(val2) : '';
        const isSame = v1 !== '' && v2 !== '' && v1 === v2;
        const isDiff = v1 !== '' && v2 !== '' && v1 !== v2;
        const highlightClass = isSame ? 'same-highlight' : '';
        const numClass = isNumeric ? 'numeric' : '';

        // Only show arrow on Player 2 column (right side)
        let diffIndicator2 = '';
        if (isDiff && isNumeric && v1 && v2) {
          const n1 = parseFloat(v1);
          const n2 = parseFloat(v2);
          if (!isNaN(n1) && !isNaN(n2)) {
            diffIndicator2 = n2 > n1
              ? '<span class="diff-arrow higher">▲</span>'
              : '<span class="diff-arrow lower">▼</span>';
          }
        }

        return `<tr class="data-row">
          <td class="label-cell">${label}</td>
          <td class="value-cell ${highlightClass} ${numClass}">${v1}</td>
          <td class="value-cell ${highlightClass} ${numClass}">${v2}${diffIndicator2}</td>
        </tr>`;
      }

      function compareHardwareRow(label, hw1, hw2) {
        const name1 = hw1?.name || '';
        const name2 = hw2?.name || '';
        const isSame = name1 !== '' && name2 !== '' && name1 === name2;
        const highlightClass = isSame ? 'same-highlight' : '';

        return `<tr class="data-row">
          <td class="label-cell">${label}</td>
          <td class="value-cell ${highlightClass}">${name1}</td>
          <td class="value-cell ${highlightClass}">${name2}</td>
        </tr>`;
      }

      player1Select.addEventListener('change', updateComparison);
      player2Select.addEventListener('change', updateComparison);

      // Initial update if params provided
      if (p1Param || p2Param) {
        updateComparison();
        updateHoqSections();
      }
    });
  </script>
</BaseLayout>

<style>
  .compare-selectors {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 2rem;
    margin: 2rem 0;
    flex-wrap: wrap;
  }

  .selector-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .selector-group label {
    color: var(--text-secondary, #9090a0);
    font-size: 0.875rem;
  }

  .selector-group select {
    background: var(--bg-card, #1a1a24);
    border: 1px solid var(--border-color, #2a2a35);
    color: var(--text-primary, #e8e8f0);
    padding: 0.75rem 1rem;
    border-radius: 6px;
    min-width: 200px;
    font-size: 1rem;
  }

  .vs-badge {
    background: var(--accent-primary, #ff6b35);
    color: white;
    font-weight: 700;
    padding: 0.5rem 1rem;
    border-radius: 4px;
    font-size: 0.875rem;
  }

  .comparison-container {
    margin-top: 2rem;
    display: flex;
    justify-content: center;
  }

