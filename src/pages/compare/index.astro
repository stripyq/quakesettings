    font-size: 0.95rem;
    padding: 0 0.25rem;
    margin-bottom: 0.85rem;
  }
  .h2h-container :global(.h2h-dual-row) {
    display: grid;
    grid-template-columns: 48px 1fr 48px;
    align-items: center;
    gap: 0.55rem;
  }
  .h2h-container :global(.h2h-dual-end) {
