  }
  /* Remove the stray last-row bottom margin to keep card padding clean */
  .h2h-container :global(.h2h-dual-card .h2h-dual-label:last-child) {
    margin-bottom: 0;
  }

  .h2h-container :global(.h2h-meta) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .h2h-container :global(.h2h-winrate) {
