    align-items: center;
    gap: 0.75rem;
    flex: 1;
  }

  .h2h-container :global(.h2h-left) {
    justify-content: flex-end;
  }

  .h2h-container :global(.h2h-right) {
    justify-content: flex-start;
  }

  .h2h-container :global(.h2h-name) {
    font-size: 0.95rem;
    font-weight: 600;
