  .h2h-container :global(.h2h-dual-end.r) { color: #a855f7; }
  .h2h-container :global(.h2h-dual-bar) {
    position: relative;
    height: 18px;
    border-radius: 999px;
    overflow: hidden;
    display: flex;
    background: var(--border-color, #2a2a35);
  }
  .h2h-container :global(.h2h-dual-bar .h2h-bar-p1) {
