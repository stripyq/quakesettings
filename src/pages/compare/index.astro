    height: 6px;
    border-radius: 3px;
    overflow: hidden;
    background: #21262d;
  }

  .h2h-container :global(.h2h-match-record-bar .h2h-bar-p1) {
    border-radius: 3px 0 0 3px;
  }

  .h2h-container :global(.h2h-match-record-bar .h2h-bar-p2) {
    border-radius: 0 3px 3px 0;
  }

  .h2h-container :global(.h2h-match-record-meta) {
    font-size: 0.75rem;
