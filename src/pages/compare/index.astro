  .h2h-container :global(.h2h-dual-bar .h2h-bar-p2) {
    border-radius: 0;
  }
  .h2h-container :global(.h2h-dual-inline-pct) {
    position: absolute;
    top: 50%;
    left: 0;
    transform: translateY(-50%);
    font-size: 0.7rem;
    font-weight: 700;
    color: #fff;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.55);
    padding: 0 0.55rem;
    pointer-events: none;
  }
  .h2h-container :global(.h2h-dual-label) {
    display: flex;
    gap: 0.4rem;
