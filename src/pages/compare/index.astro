    flex-direction: column;
    gap: 0.1rem;
  }

  .h2h-container :global(.h2h-stat-block) {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .h2h-container :global(.h2h-align-right) {
    align-items: flex-end;
  }

  .h2h-container :global(.h2h-align-left) {
    align-items: flex-start;
  }

  .h2h-container :global(.h2h-kill-count) {
    font-size: 1.75rem;
    font-weight: 800;
    font-family: monospace;
    line-height: 1;
    color: var(--text-primary, #e8e8f0);
  }

  .h2h-container :global(.h2h-kill-label) {
