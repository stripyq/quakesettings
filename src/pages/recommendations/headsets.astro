---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;

// Get all players to count hardware usage
const allPlayers = await getCollection('players');
const players = allPlayers.filter(p => p.data.published !== false);

// Create headset usage map and player list map
const headsetUsageMap = new Map<string, number>();
const headsetPlayersMap = new Map<string, typeof players>();
players.forEach(p => {
  const headsetId = p.data.headset;
  if (headsetId) {
    headsetUsageMap.set(headsetId, (headsetUsageMap.get(headsetId) || 0) + 1);
    if (!headsetPlayersMap.has(headsetId)) {
      headsetPlayersMap.set(headsetId, []);
    }
    headsetPlayersMap.get(headsetId)!.push(p);
  }
});

// Map recommendation names to hardware slugs
const headsetSlugMap: Record<string, string[]> = {
  "Audeze Maxwell": ["audeze-maxwell"],
  "SteelSeries Arctis Nova Pro Wireless": ["steelseries-arctis-nova-pro-wireless"],
  "SteelSeries Arctis Nova Elite": ["steelseries-arctis-nova-elite"],
  "Asus ROG Delta 2 Wireless": ["asus-rog-delta-2-wireless"],
  "Alienware Pro Wireless": ["alienware-pro-wireless"],
  "Sony Inzone H5": ["sony-inzone-h5"],
  "SteelSeries Arctis Nova 3X": ["steelseries-arctis-nova-3x"],
  "Razer BlackShark V3X": ["razer-blackshark-v3x"],
  "Logitech G435": ["logitech-g435"],
  "Drop EPOS PC38X": ["drop-epos-pc38x"],
  "Beyerdynamic DT 900 Pro X": ["beyerdynamic-dt-900-pro-x"],
  "Turtle Beach Atlas Air": ["turtle-beach-atlas-air"],
  "Astro A50X": ["astro-a50x"],
  "Fosi K7": ["fosi-k7"],
  "Sennheiser HD560S": ["sennheiser-hd560s"],
  "Audio-Technica AD700X": ["audio-technica-ad700x"],
  "AKG K702": ["akg-k702"],
  "Beyerdynamic DT880": ["beyerdynamic-dt880"],
  "Sennheiser HD598/HD599": ["sennheiser-hd598", "sennheiser-hd599"],
};

function getPlayerCount(name: string): number {
  const slugs = headsetSlugMap[name];
  if (!slugs) return 0;
  let total = 0;
  slugs.forEach(slug => {
    total += headsetUsageMap.get(slug) || 0;
  });
  return total;
}

function getPlayersForHeadset(name: string): typeof players {
  const slugs = headsetSlugMap[name];
  if (!slugs) return [];
  const result: typeof players = [];
  slugs.forEach(slug => {
    const playersForSlug = headsetPlayersMap.get(slug);
    if (playersForSlug) {
      result.push(...playersForSlug);
    }
  });
  return result;
}

function priceBadgeClass(price: string): string {
  if (price === '$$$$') return 'price-badge price-legendary';
  if (price === '$$$') return 'price-badge price-premium';
  if (price === '$$') return 'price-badge price-mid';
  return 'price-badge price-budget';
}

const wirelessGaming = [
  { name: "Audeze Maxwell", type: "Wireless Closed", price: "$$$", gt: true, bs: true, jv: true, asr: false, mle: false },
  { name: "SteelSeries Arctis Nova Pro Wireless", type: "Wireless Closed", price: "$$$", gt: true, bs: true, jv: false, asr: false, mle: false },
  { name: "SteelSeries Arctis Nova Elite", type: "Wireless Closed", price: "$$$$", gt: true, bs: false, jv: false, asr: false, mle: false },
  { name: "Asus ROG Delta 2 Wireless", type: "Wireless Closed", price: "$$", gt: true, bs: false, jv: false, asr: false, mle: false },
  { name: "Alienware Pro Wireless", type: "Wireless Closed", price: "$$$", gt: true, bs: false, jv: false, asr: false, mle: false },
  { name: "Sony Inzone H5", type: "Wireless Closed", price: "$$", gt: true, bs: false, jv: false, asr: false, mle: false },
];

const budgetOptions = [
  { name: "SteelSeries Arctis Nova 3X", type: "USB-C Wireless", price: "$$", gt: true, bs: false, jv: false, asr: false, mle: false },
  { name: "Razer BlackShark V3X", type: "Wired", price: "$", gt: true, bs: false, jv: false, asr: false, mle: false },
  { name: "Logitech G435", type: "Wireless", price: "$", gt: true, bs: false, jv: false, asr: false, mle: false },
];

const audiophile = [
  { name: "Drop EPOS PC38X", type: "Wired Open", price: "$$", gt: false, bs: true, jv: false, asr: true, mle: true },
  { name: "Beyerdynamic DT 900 Pro X", type: "Wired Open", price: "$$$", gt: false, bs: false, jv: true, asr: true, mle: false },
  { name: "Turtle Beach Atlas Air", type: "Wireless Open", price: "$$", gt: false, bs: false, jv: true, asr: false, mle: false },
  { name: "Sennheiser HD560S", type: "Wired Open", price: "$$", gt: false, bs: false, jv: false, asr: true, mle: false },
  { name: "Audio-Technica AD700X", type: "Wired Open", price: "$", gt: false, bs: false, jv: false, asr: true, mle: true },
  { name: "AKG K702", type: "Wired Open", price: "$$", gt: false, bs: false, jv: false, asr: false, mle: true },
  { name: "Beyerdynamic DT880", type: "Wired Semi-Open", price: "$$", gt: false, bs: false, jv: false, asr: false, mle: true },
  { name: "Sennheiser HD598/HD599", type: "Wired Open", price: "$", gt: false, bs: false, jv: false, asr: false, mle: true },
];

const dacAmp = [
  { name: "Fosi K7", category: "DAC/AMP", price: "$$", notes: "Recommended for DT880, DT900 Pro X, and other high-impedance headphones that benefit from amplification" },
];

const specialty = [
  { name: "Astro A50X", category: "Best Mic + Console", price: "$$$", notes: "HDMI 2.1 switching" },
];

function countRecs(h: { gt?: boolean; bs?: boolean; jv?: boolean; asr?: boolean; mle?: boolean }) {
  return (h.gt ? 1 : 0) + (h.bs ? 1 : 0) + (h.jv ? 1 : 0) + (h.asr ? 1 : 0) + (h.mle ? 1 : 0);
}

const schema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Recommended Gaming Headsets for Quake Live",
  "description": "Best gaming headsets for competitive Quake Live",
  "url": "https://stripyq.github.io/quakesettings/recommendations/headsets/"
};
---

<BaseLayout title="Headset Recommendations" description="Best gaming headsets for Quake Live. Audio clarity and comfort picks from competitive players." schema={schema} ogImage="/images/og/recommendations.jpg">
  <div class="page-header">
    <h1>Headset Recommendations</h1>
    <p>Recommended headsets from top reviewers (2025)</p>
  </div>

  <div class="reviewer-legend">
    <span class="legend-item"><span class="badge gt">GT</span> GadgetryTech</span>
    <span class="legend-item"><span class="badge bs">BS</span> BadSeed Tech</span>
    <span class="legend-item"><span class="badge jv">JV</span> Joshua Valour</span>
    <span class="legend-item"><span class="badge asr">ASR</span> Audio Science Review</span>
    <span class="legend-item"><span class="badge mle">MLE</span> Mad Lust Envy (Head-Fi Gaming Guide)</span>
  </div>

  <div class="price-legend">
    <span><span class="price-badge price-budget">$</span> Budget (&lt;$80)</span>
    <span><span class="price-badge price-mid">$$</span> Mid ($80-200)</span>
    <span><span class="price-badge price-premium">$$$</span> Premium ($200-400)</span>
    <span><span class="price-badge price-legendary">$$$$</span> Flagship ($400+)</span>
  </div>

  <h2 class="section-title">Wireless Gaming</h2>
  <div class="table-container">
    <table class="rec-table">
      <thead>
        <tr>
          <th>Headset</th>
          <th>Type</th>
          <th>Price</th>
          <th title="GadgetryTech">GT</th>
          <th title="BadSeed Tech">BS</th>
          <th title="Joshua Valour">JV</th>
          <th title="Audio Science Review">ASR</th>
          <th title="Mad Lust Envy (Head-Fi Gaming Guide)">MLE</th>
          <th>Players</th>
        </tr>
      </thead>
      <tbody>
        {wirelessGaming.map(h => {
          const playerCount = getPlayerCount(h.name);
          return (
            <tr>
              <td class="headset-name">{h.name}</td>
              <td>{h.type}</td>
              <td><span class={priceBadgeClass(h.price)}>{h.price}</span></td>
              <td class="center">{h.gt ? '✓' : ''}</td>
              <td class="center">{h.bs ? '✓' : ''}</td>
              <td class="center">{h.jv ? '✓' : ''}</td>
              <td class="center">{h.asr ? '✓' : ''}</td>
              <td class="center">{h.mle ? '✓' : ''}</td>
              <td class="center players">
                {playerCount > 0 ? (
                  <div class="usage-wrapper">
                    <span class="usage-count">{playerCount}</span>
                    <div class="player-dropdown">
                      {getPlayersForHeadset(h.name).map(p => (
                        <a href={`${base}players/${p.id}/`}>{p.data.name}</a>
                      ))}
                    </div>
                  </div>
                ) : '—'}
              </td>
            </tr>
          );
        })}
      </tbody>
    </table>
  </div>

  <h2 class="section-title">Budget Wireless/Wired</h2>
  <div class="table-container">
    <table class="rec-table">
      <thead>
        <tr>
          <th>Headset</th>
          <th>Type</th>
          <th>Price</th>
          <th title="GadgetryTech">GT</th>
          <th title="BadSeed Tech">BS</th>
          <th title="Joshua Valour">JV</th>
