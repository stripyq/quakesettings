        })}
      </tbody>
    </table>
  </div>

  <h2 class="section-title">DAC / AMP</h2>
  <div class="table-container">
    <table class="rec-table">
      <thead>
        <tr>
          <th>Item</th>
          <th>Category</th>
          <th>Price</th>
          <th>Notes</th>
